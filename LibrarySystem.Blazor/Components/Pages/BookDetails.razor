@page "/books/{id:int}"
@rendermode InteractiveServer
@using LibrarySystem.Data
@using LibrarySystem.Core.Models
@using Microsoft.EntityFrameworkCore
@inject LibraryContext Context

<PageTitle>Bokdetaljer</PageTitle>

<h1>Bokdetaljer</h1>

@if (book == null)
{
    <p>Laddar...</p>
}
else
{
    <div class="card p-3">
        <h3>@book.Title</h3>

        <p><strong>ISBN:</strong> @book.ISBN</p>
        <p><strong>Författare:</strong> @book.Author</p>
        <p><strong>Utgivningsår:</strong> @book.PublishedYear</p>

        <p>
            <strong>Status:</strong>
            @if (book.IsAvailable)
            {
                <span class="text-success">Tillgänglig</span>
            }
            else
            {
                <span class="text-danger">Utlånad</span>
            }
        </p>

        @if (currentLoan != null && !currentLoan.IsReturned)
        {
            <hr />
            <h4>Aktivt lån</h4>
            <p><strong>Utlånad till:</strong> @currentLoan.Member.Name</p>
            <p><strong>Lånedatum:</strong> @currentLoan.LoanDate.ToString("yyyy-MM-dd")</p>
            <p><strong>Förfallodatum:</strong> @currentLoan.DueDate.ToString("yyyy-MM-dd")</p>
        }
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Book? book;
    private Loan? currentLoan;

    protected override async Task OnInitializedAsync()
    {
        book = await Context.Books.FirstOrDefaultAsync(b => b.Id == Id);

        if (book != null)
        {
            currentLoan = await Context.Loans
                .Include(l => l.Member)
                .FirstOrDefaultAsync(l => l.BookId == book.Id && l.ReturnDate == null);
        }
    }
}